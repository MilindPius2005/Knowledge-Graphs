{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Ontology: Backend",
      "type": "process",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": ["ontology.py"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "ontology-backend",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Serving Flask app",
          "endsPattern": "Running on http://127.0.0.1:5000"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Ontology: Frontend",
      "type": "process",
      "command": "corepack",
      "args": ["pnpm", "run", "dev"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "ontology-frontend",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "vite",
          "endsPattern": "Local:.*5173"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Ontology: Run Full App",
      "dependsOrder": "parallel",
      "dependsOn": [
        "Ontology: Backend",
        "Ontology: Frontend"
      ],
      "problemMatcher": []
    }
  ]
}
